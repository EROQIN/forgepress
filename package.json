{
  "name": "forgepress",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @forgepress/web dev",
    "build": "pnpm build:packages && pnpm build:pages && pnpm build:cf",
    "build:packages": "pnpm --filter @forgepress/content --filter @forgepress/theme build",
    "build:web": "pnpm --filter @forgepress/web build",
    "build:pages": "pnpm --filter @forgepress/pages build",
    "build:cf": "pnpm --filter @forgepress/web exec opennextjs-cloudflare build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "preview:cf": "pnpm --filter @forgepress/web preview",
    "deploy:cf": "pnpm --filter @forgepress/web deploy",
    "deploy:cf:built": "pnpm --filter @forgepress/web exec wrangler deploy --config ../../wrangler.jsonc",
    "upload:cf:built": "pnpm --filter @forgepress/web exec wrangler versions upload --config ../../wrangler.jsonc",
    "deploy:pages": "pnpm --filter @forgepress/pages deploy",
    "cf:bootstrap": "node scripts/cloudflare-bootstrap.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
