---
import { seedPosts } from "@forgepress/content";
import "../../styles/editorial.css";

export function getStaticPaths() {
  return seedPosts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const lines = post.content.split("\n");
const headings = lines.filter((line: string) => line.startsWith("## ")).map((line: string) => line.slice(3));
const headingId = (value: string) => value.trim().toLowerCase().replace(/[\s/]+/g, "-").replace(/[^\p{L}\p{N}-]/gu, "");
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{post.title} · ForgePress</title>
    <meta name="description" content={post.excerpt} />
  </head>
  <body>
    <nav class="nav shell">
      <a class="brand" href="/">✦ ForgePress</a>
      <div class="nav-links"><a href="/">返回文章</a><a href={`/posts/${post.slug}/`}>开始阅读</a></div>
    </nav>

    <main class="article-shell">
      <header class="article-head">
        <small>{post.tags[0]} · {new Date(post.publishedAt).toLocaleDateString("zh-CN")} · {post.readingMinutes} 分钟阅读</small>
        <h1>{post.title}</h1>
        <p>{post.excerpt}</p>
      </header>

      <div class="cover" role="img" aria-label="夜间森林与植物文章封面"></div>

      <div class="article-grid">
        <article class="article">
          {lines.map((line: string) => {
            if (line.startsWith("# ")) return null;
            if (line.startsWith("## ")) return <h2 id={headingId(line.slice(3))}>{line.slice(3)}</h2>;
            if (line.startsWith("### ")) return <h3 id={headingId(line.slice(4))}>{line.slice(4)}</h3>;
            if (!line.trim()) return null;
            return <p>{line}</p>;
          })}
        </article>
        <aside class="aside">
          <h2>文章目录</h2>
          {headings.length ? headings.map((heading: string) => <a href={`#${headingId(heading)}`}>{heading}</a>) : <span>本篇暂无分节</span>}
        </aside>
      </div>
    </main>
  </body>
</html>
