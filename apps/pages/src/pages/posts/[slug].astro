---
import { seedPosts } from "@forgepress/content";

export function getStaticPaths() {
  return seedPosts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const lines = post.content.split("\n");
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{post.title} · ForgePress</title>
    <meta name="description" content={post.excerpt} />
    <style>
      :root{color-scheme:dark}*{box-sizing:border-box}body{margin:0;background:#0e1024;color:#f7f5ff;font-family:Inter,"Noto Sans SC",system-ui,sans-serif}.shell{width:min(calc(100% - 36px),760px);margin:auto}nav{padding:28px 0}nav a{color:#5ee7f7;text-decoration:none}.head{padding:70px 0 34px;border-bottom:1px solid rgba(255,255,255,.13)}.head h1{font-size:clamp(42px,8vw,68px);line-height:1.08;letter-spacing:-.045em}.head p{color:#b9b5d1;font-size:18px;line-height:1.8}.article{margin:36px auto 80px;padding:36px;border:1px solid rgba(255,255,255,.13);border-radius:28px;background:rgba(26,29,62,.76);font-family:"Noto Serif SC",serif;font-size:18px;line-height:1.95}.article h1,.article h2{font-family:Inter,"Noto Sans SC",sans-serif}.article code{font-family:monospace;color:#ffd1e6;background:rgba(255,122,182,.12);padding:2px 6px;border-radius:6px}@media(max-width:600px){.article{padding:24px}}
    </style>
  </head>
  <body>
    <nav class="shell"><a href="/">← 返回首页</a></nav>
    <header class="head shell"><h1>{post.title}</h1><p>{post.excerpt}</p></header>
    <article class="article shell">
      {lines.map((line) => line.startsWith("# ") ? <h1>{line.slice(2)}</h1> : line.startsWith("## ") ? <h2>{line.slice(3)}</h2> : line ? <p>{line}</p> : <br />)}
    </article>
  </body>
</html>
