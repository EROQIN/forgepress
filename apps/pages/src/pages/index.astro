---
import { seedPosts } from "@forgepress/content";
import { siteConfig } from "@forgepress/theme";
import "../styles/editorial.css";

const [featured, ...latest] = seedPosts;
if (!featured) throw new Error("ForgePress requires at least one published seed post.");
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={siteConfig.description} />
    <title>{siteConfig.title} · Pages Edition</title>
  </head>
  <body>
    <nav class="nav shell">
      <a class="brand" href="/">✦ ForgePress</a>
      <div class="nav-links">
        <a href="#latest">文章</a>
        <a href="#latest">归档</a>
        <a href="#latest">专题</a>
        <a href={`/posts/${featured.slug}/`}>开始阅读</a>
      </div>
    </nav>

    <main>
      <section class="hero shell">
        <div>
          <h1>记录思考，<br />构建未来。</h1>
          <p>{siteConfig.tagline}</p>
          <div class="actions">
            <a class="button primary" href={`/posts/${featured.slug}/`}>开始阅读</a>
            <a class="button" href="#latest">浏览文章</a>
          </div>
        </div>
        <div class="visual">
          <a class="featured" href={`/posts/${featured.slug}/`}>
            <small>本期精选</small>
            <h2>{featured.title}</h2>
            <p>{featured.excerpt}</p>
          </a>
        </div>
      </section>

      <section class="section shell" id="latest">
        <h2>最近文章</h2>
        <div class="ledger">
          {latest.map((post, index) => (
            <a class="row" href={`/posts/${post.slug}/`}>
              <span class="index">{String(index + 1).padStart(2, "0")}</span>
              <div>
                <h3>{post.title}</h3>
                <p>{post.excerpt}</p>
              </div>
              <small>{post.readingMinutes} 分钟阅读</small>
            </a>
          ))}
        </div>
      </section>
    </main>

    <footer class="footer shell">
      <span>© {new Date().getFullYear()} ForgePress</span>
      <span>Cloudflare Pages 静态发行版</span>
    </footer>
  </body>
</html>
