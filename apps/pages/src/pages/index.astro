---
import { seedPosts } from "@forgepress/content";
import { siteConfig } from "@forgepress/theme";
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={siteConfig.description} />
    <title>{siteConfig.title} · Pages Edition</title>
    <style>
      :root{color-scheme:dark;--bg:#0e1024;--surface:rgba(26,29,62,.78);--text:#f7f5ff;--muted:#b9b5d1;--pink:#ff7ab6;--violet:#9b7bff;--cyan:#5ee7f7}
      *{box-sizing:border-box}body{margin:0;background:radial-gradient(circle at 20% 0,rgba(155,123,255,.22),transparent 34%),radial-gradient(circle at 95% 20%,rgba(255,122,182,.16),transparent 30%),var(--bg);color:var(--text);font-family:Inter,"Noto Sans SC",system-ui,sans-serif;min-height:100vh}
      .shell{width:min(calc(100% - 36px),1080px);margin:auto}.nav{display:flex;justify-content:space-between;align-items:center;padding:24px 0}.brand{font-size:22px;font-weight:900}.badge,.tag{border:1px solid rgba(255,255,255,.14);border-radius:999px;padding:7px 10px;color:var(--cyan);font-size:11px}
      .hero{padding:100px 0 70px}.hero span{color:var(--cyan);letter-spacing:.16em;font-size:12px;font-weight:900}.hero h1{font-size:clamp(52px,9vw,92px);line-height:.96;letter-spacing:-.06em;margin:22px 0}.hero h1 em{font-style:normal;color:transparent;background:linear-gradient(90deg,var(--pink),var(--violet),var(--cyan));background-clip:text}.hero p{color:var(--muted);font-size:18px;line-height:1.8;max-width:650px}
      .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;padding-bottom:80px}.card{display:block;min-height:310px;padding:24px;border:1px solid rgba(255,255,255,.13);border-radius:24px;background:var(--surface);color:inherit;text-decoration:none;box-shadow:0 22px 70px rgba(0,0,0,.25);transition:.25s}.card:hover{transform:translateY(-6px);border-color:rgba(155,123,255,.55)}.card h2{font-size:24px;line-height:1.25}.card p{color:var(--muted);line-height:1.7}.tags{display:flex;flex-wrap:wrap;gap:7px}
      footer{padding:28px 0;border-top:1px solid rgba(255,255,255,.12);color:var(--muted);display:flex;justify-content:space-between}
      @media(max-width:820px){.grid{grid-template-columns:1fr}.hero{padding-top:70px}}
      @media(prefers-reduced-motion:reduce){.card{transition:none}}
    </style>
  </head>
  <body>
    <nav class="nav shell">
      <div class="brand">✦ ForgePress</div>
      <span class="badge">CLOUDFLARE PAGES EDITION</span>
    </nav>
    <header class="hero shell">
      <span>STATIC SIGNAL FROM THE EDGE</span>
      <h1>把技术写作<br />变成一场<em>星际旅行</em>。</h1>
      <p>{siteConfig.tagline} 这是适合 Fork、分享和快速上线的静态发行版；完整后台、D1 与 R2 请使用 Workers 版本。</p>
    </header>
    <main class="grid shell">
      {seedPosts.map((post) => (
        <a class="card" href={`/posts/${post.slug}/`}>
          <div class="tags">{post.tags.slice(0,2).map((tag) => <span class="tag">{tag}</span>)}</div>
          <h2>{post.title}</h2>
          <p>{post.excerpt}</p>
          <small>{post.readingMinutes} 分钟阅读</small>
        </a>
      ))}
    </main>
    <footer class="shell"><span>ForgePress Pages Edition</span><span>✦ static & portable</span></footer>
  </body>
</html>
